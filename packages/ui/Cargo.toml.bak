[package]
name = "ui"
version = "0.1.0"
edition = "2021"

[dependencies]
dioxus = { workspace = true }
[dev-dependencies]
dioxus = { workspace = true, features = ["ssr"] }
futures-timer = "3"
lucide-dioxus = { version = "2", features = ["all-icons"] }
tailwind_fuse = { git = "https://github.com/slack2450/tailwind-fuse", branch = "main" }
[lints]
workspace = true
